# --- Database ---
# In locale; su Railway viene fornito DATABASE_URL (postgresql://...), viene
# convertito automaticamente al driver asyncpg in app/config.py.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/spese

# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-xxxxx
# Modello configurabile: per la massima competenza puoi usare un modello Opus.
ANTHROPIC_MODEL=claude-sonnet-4-6
# Budget generoso per scontrini multipagina e verifiche fiscali.
AGENT_MAX_TOKENS=8192
AGENT_MAX_TOOL_ITERATIONS=24
# Risparmio token: prompt caching del prefisso (tools + system + cronologia,
# incluso il file dell'upload). TTL "5m" o "1h". Finestra mobile sulla cronologia
# di chat (0 = illimitato). Logging dell'uso token per misurare il risparmio.
ENABLE_PROMPT_CACHING=true
PROMPT_CACHE_TTL=5m
CHAT_HISTORY_MAX_MESSAGES=40
LOG_TOKEN_USAGE=false
# Ricerca web dell'agente per affinare/verificare le regole fiscali aggiornate.
ENABLE_WEB_SEARCH=true
WEB_SEARCH_MAX_USES=6
WEB_SEARCH_COUNTRY=IT

# --- Agente di orchestrazione (revisione in background) ---
# Verifica la coerenza dei dati (righe ↔ totali, classificazioni, duplicati),
# segnala righe non calcolate/gestite correttamente e propone miglioramenti
# (categorie, riclassificazioni) applicati solo previo consenso.
ENABLE_ORCHESTRATOR=true
# Esegue una revisione mirata al termine di ogni caricamento documento.
ORCHESTRATOR_RUN_AFTER_UPLOAD=true
# Abilita la fase LLM (proposte intelligenti); senza API key restano le sole
# verifiche deterministiche.
ORCHESTRATOR_USE_LLM=true
ORCHESTRATOR_MAX_TOOL_ITERATIONS=12
# Scheduler periodico interno (ore). 0 = disattivato (default). Es. 24 = giornaliero.
ORCHESTRATOR_SCHEDULE_HOURS=0

# --- Auth ---
JWT_SECRET=cambia-questa-stringa
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
# Codice di recupero per reimpostare la password via GUI quando si è chiusi fuori
# (es. admin senza codice fiscale). Vuoto = funzione disattivata. Imposta un
# valore lungo e segreto e usalo nella schermata "Password dimenticata?".
ADMIN_RECOVERY_KEY=

# --- Storage documenti ---
# local = volume su filesystem (su Railway monta un Volume su STORAGE_DIR)
STORAGE_BACKEND=local
STORAGE_DIR=/data/documents

# --- Ricerca semantica (opzionale, richiede pgvector + provider embedding) ---
ENABLE_SEMANTIC_SEARCH=false
EMBEDDING_PROVIDER=voyage
EMBEDDING_MODEL=voyage-3
EMBEDDING_DIM=1024
VOYAGE_API_KEY=

# --- App ---
# In deploy imposta APP_ENV=production: l'app rifiuta di partire se DATABASE_URL
# punta ancora al Postgres locale di default (evita errori criptici a runtime).
APP_ENV=development
CORS_ORIGINS=*
